# Nexa Motion environment configuration
# Copy this file to .env.local and fill in real values.
#
# The app is fully runnable with NO env vars — the AI Coach uses
# high-quality curated responses out of the box.

# ─── AI Coach (optional, but recommended for production) ─────────────────
# Priority: ANTHROPIC_API_KEY → OPENAI_API_KEY → curated mock fallback.
# Set whichever you prefer; both can be set (Anthropic wins).

# Anthropic (Claude) — recommended
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Netlify ─────────────────────────────────────────────────────────────
# In Netlify, set these as environment variables in:
#   Site settings → Build & deploy → Environment → Environment variables
# The API route at /api/chat runs as a Netlify Function — no extra config.

# ─── Web Push notifications ──────────────────────────────────────────────
# Required to actually deliver daily reminders to users' devices.
# Generate a keypair locally with:  npm run vapid
# Then paste the values into Vercel -> Project settings -> Environment Variables.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:you@example.com

# Vercel Cron Jobs send this as `Authorization: Bearer <CRON_SECRET>` so
# /api/cron/daily-reminder can reject unauthenticated requests. Generate any
# random string (e.g. `openssl rand -hex 32`).
CRON_SECRET=

# ─── Vercel KV (auto-injected when you connect a KV store in Vercel) ────
# You should NOT need to set these by hand — Vercel adds them automatically
# once you connect a KV database under Storage in the project dashboard.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── Future: auth + persistence ──────────────────────────────────────────
# Wire these up in lib/store.ts once you've created a project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
