# Nexa Motion environment configuration
# Copy this file to .env.local and fill in real values.

# Optional: enable real OpenAI responses in the AI Coach.
# Without a key, the app falls back to high-quality mock responses
# so you can run and demo Nexa Motion immediately.
OPENAI_API_KEY=

# Optional: swap in any compatible model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Firebase / Supabase / Auth providers
# Wire these up in lib/store.ts once you've created a project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
